# Public (exposto ao browser)
NEXT_PUBLIC_BASE_URL=https://seu-dominio.com
NEXT_PUBLIC_META_PIXEL_ID=
# Microsoft Clarity (opcional; padrão interno vrqffcb4hs se não definir no componente)
NEXT_PUBLIC_CLARITY_ID=vrqffcb4hs
# Atraso em ms antes do VSL em tela cheia (0 = abrir imediatamente; padrão 4000)
NEXT_PUBLIC_VSL_DELAY_MS=4000
# Com vsl-workshop.mp4 em /public, use 1 para carregar MP4 antes do .mov
# NEXT_PUBLIC_VSL_PREFER_MP4=1
# Opcional: endpoint POST para correlacionar erros JS com sessões (ex. webhook / API)
# NEXT_PUBLIC_ERROR_REPORT_URL=https://...
